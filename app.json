{
  "expo": {
    "name": "Probaly",
    "slug": "probaly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/probaly-logo.png",
    "scheme": "probaly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.probaly.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app does not use the camera.",
        "NSPhotoLibraryUsageDescription": "This app does not access photos.",
        "NSLocationWhenInUseUsageDescription": "This app does not use location.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIUserInterfaceStyle": "Automatic"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#1A237E",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.probaly.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/probaly-logo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/probaly-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#111827"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/probaly-logo.png",
          "color": "#1A237E",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
